{
  "name": "@haddowg/json-api-query",
  "version": "1.0.0",
  "description": "TanStack Query bindings for the JSON:API client: option/key factories + type:id cache normalization.",
  "license": "MIT",
  "author": "Gregory Haddow (https://github.com/haddowg)",
  "homepage": "https://haddowg.github.io/json-api-ts/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haddowg/json-api-ts.git",
    "directory": "packages/query"
  },
  "bugs": "https://github.com/haddowg/json-api-ts/issues",
  "keywords": [
    "json-api",
    "jsonapi",
    "typescript",
    "tanstack-query",
    "react-query",
    "cache",
    "normalization",
    "openapi"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint:publish": "publint --strict && attw --pack ."
  },
  "dependencies": {
    "@haddowg/json-api-client": "workspace:^"
  },
  "peerDependencies": {
    "@tanstack/query-core": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.0.0"
  }
}
