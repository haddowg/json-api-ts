{
  "name": "@haddowg/json-api-client",
  "version": "0.0.0",
  "description": "Generic, framework-agnostic runtime for a typesafe JSON:API client. Parameterised by a generated descriptor.",
  "license": "MIT",
  "author": "Gregory Haddow (https://github.com/haddowg)",
  "homepage": "https://haddowg.github.io/json-api-ts/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haddowg/json-api-ts.git",
    "directory": "packages/client"
  },
  "bugs": "https://github.com/haddowg/json-api-ts/issues",
  "keywords": [
    "json-api",
    "jsonapi",
    "typescript",
    "typed",
    "client",
    "openapi",
    "rest",
    "api"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ajv": {
      "import": {
        "types": "./dist/ajv.d.mts",
        "default": "./dist/ajv.mjs"
      },
      "require": {
        "types": "./dist/ajv.d.cts",
        "default": "./dist/ajv.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "ajv": [
        "./dist/ajv.d.cts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint:publish": "publint --strict && attw --pack ."
  },
  "peerDependencies": {
    "ajv": "^8.17.1"
  },
  "peerDependenciesMeta": {
    "ajv": {
      "optional": true
    }
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  }
}
