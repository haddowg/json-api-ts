{
  "name": "@haddowg/json-api-codegen",
  "version": "0.0.0",
  "description": "CLI that reads the json-api-symfony OpenAPI spec (+ JSON Schemas) and emits a typed client descriptor.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "json-api-codegen": "./dist/cli.mjs",
    "japi": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@haddowg/json-api-client": "workspace:^",
    "yaml": "^2.7.0"
  }
}
