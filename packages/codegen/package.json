{
  "name": "@haddowg/json-api-codegen",
  "version": "0.0.0",
  "description": "CLI that reads the json-api-symfony OpenAPI spec (+ JSON Schemas) and emits a typed client descriptor.",
  "license": "MIT",
  "author": "Gregory Haddow (https://github.com/haddowg)",
  "homepage": "https://haddowg.github.io/json-api-ts/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haddowg/json-api-ts.git",
    "directory": "packages/codegen"
  },
  "bugs": "https://github.com/haddowg/json-api-ts/issues",
  "keywords": [
    "json-api",
    "jsonapi",
    "typescript",
    "openapi",
    "codegen",
    "code-generation",
    "cli",
    "api"
  ],
  "type": "module",
  "bin": {
    "json-api-codegen": "./dist/cli.mjs",
    "japi": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint:publish": "publint --strict && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@haddowg/json-api-client": "workspace:^",
    "yaml": "^2.7.0"
  }
}
