{
  "name": "@haddowg/json-api-codegen",
  "version": "0.0.0",
  "description": "CLI that reads the json-api-symfony OpenAPI spec (+ JSON Schemas) and emits a typed client descriptor.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "json-api-codegen": "./dist/cli.js",
    "japi": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  }
}
