# Leave everything unset to run against the seeded in-memory mock (the default — no backend).
#
# LIVE MODE — point the app at the running FrankenPHP bundle example:
#   1. start the backend:  (from the bundle repo) docker run --rm -p 8080:80 json-api-symfony-example
#   2. set VITE_API_URL=/api  — the app then goes through the Vite dev-proxy (same-origin, no CORS).
#      The proxy forwards /api/* to VITE_API_PROXY_TARGET (default http://localhost:8080).
# VITE_API_URL=/api
# VITE_API_PROXY_TARGET=http://localhost:8080
#
# The example secures playlist writes behind a Bearer firewall where the token IS the user id.
# `ada@example.com` owns the seeded "Morning Mix" playlist, so set this to edit it live (reads
# work without a token).
# VITE_API_TOKEN=ada@example.com
